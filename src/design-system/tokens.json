{
  "$description": "KRU design tokens — direction Fight Card (billet perforé). Version JSON framework-agnostique (miroir de tokens.ts).",
  "color": {
    "cream": "#ECE3CE",
    "paper": "#F5EEDD",
    "paperAlt": "#F0D9C8",
    "ink": "#17130E",
    "inkSoft": "#4A3D2E",
    "muted": "#6E5B45",
    "hairline": "#D8CBAE",
    "red": "#B0201F",
    "redDark": "#7A2018",
    "redInk": "#F3E9D2",
    "amber": "#E6A24C",
    "onInk": "#ECE3CE",
    "onInkMuted": "#C9BCA6",
    "onInkFaint": "#9A8E78",
    "win": "#B0201F",
    "loss": "#17130E"
  },
  "status": {
    "pending":  { "bg": "#B0201F", "fg": "#F3E9D2" },
    "accepted": { "bg": "#17130E", "fg": "#E6A24C" },
    "sent":     { "bg": "#6E5B45", "fg": "#ECE3CE" },
    "refused":  { "bg": "#6E5B45", "fg": "#ECE3CE" }
  },
  "spacing": { "xxs": 4, "xs": 6, "sm": 8, "md": 12, "lg": 14, "xl": 16, "2xl": 18, "3xl": 22, "4xl": 26 },
  "font": {
    "display": "Anton",
    "ui": "Barlow Condensed",
    "mono": "Space Mono"
  },
  "fontSize": {
    "micro": 8.5, "caption": 10, "small": 11.5, "body": 13, "bodyLg": 14,
    "h6": 19, "h5": 20, "h4": 26, "h3": 34, "h2": 44, "display": 52
  },
  "fontWeight": { "regular": 400, "medium": 500, "semibold": 600, "bold": 700 },
  "letterSpacing": { "tight": "-.5px", "normal": "0", "wide": "1px", "wider": "1.5px", "widest": "3px" },
  "border": {
    "card": "1.5px solid #17130E",
    "hairlineDashed": "1.5px dashed #17130E",
    "masthead": "3px solid #B0201F",
    "radius": 0
  },
  "shadow": {
    "frame": "0 0 90px rgba(0,0,0,.7)",
    "toast": "0 12px 30px rgba(0,0,0,.5)"
  },
  "layout": {
    "phoneMaxWidth": 428,
    "mastheadHeight": 52,
    "bottomNavHeight": 50,
    "notchDiameter": 18
  },
  "motion": {
    "fadeIn": "fcfade .3s ease",
    "toastIn": "fctoast .3s ease",
    "toastDurationMs": 3200
  }
}
